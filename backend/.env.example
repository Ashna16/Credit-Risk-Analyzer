# Copy to `.env` and adjust. Docker Compose reads `POSTGRES_*` from `.env` in `backend/`.

POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me
POSTGRES_DB=credit_analyzer

# Host machine (TablePlus, GUI): Docker publishes Postgres on port 5433 by default (see docker-compose.yml).
# Port 5432 is often taken by Postgres.app — use 5433 for Docker, or stop Postgres.app and map 5432:5432.
DATABASE_URL=postgresql://postgres:change_me@127.0.0.1:5433/credit_analyzer
PGPORT=5433

# Optional: local dev without Docker (file-based SQLite)
# DATABASE_URL=sqlite:///./credit_analyzer_dev.db

UPLOAD_FOLDER=./uploads

# --- Viewing data ---
# TablePlus: ./scripts/open_tableplus_credit_analyzer.sh  (uses PGPORT, default 5433 for Docker)
# Terminal:  ./scripts/inspect_credit_database.sh
# If you see "database credit_analyzer does not exist" on port 5432, you were hitting Postgres.app—use port 5433 (Docker) or stop Postgres.app.
